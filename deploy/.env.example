# ───────────────────────────────────────────────────────────
# 지니야빌더 배포 환경변수 (Render → Environment 탭에 입력)
# ★실제 키 값은 여기 적지 말고 Render 대시보드에만 입력하세요.
# ───────────────────────────────────────────────────────────

# ── LLM / RAG ──
OPENAI_API_KEY=sk-...
PINECONE_API_KEY=...
ANTHROPIC_API_KEY=sk-ant-...

# ── 개인화 벡터 메모리 (v4.0 Step 2-A · Pinecone) ──
# PINECONE_API_KEY 위에 있음(신규). 없으면 개인화 메모리는 자동 비활성(대화는 그대로).
PINECONE_INDEX=ohwant-genya        # 인덱스명(없으면 최초 사용 시 자동 생성: 1536차원·cosine·aws us-east-1)

# ── 구글 OAuth (회원 로그인) ──
GOOGLE_OAUTH_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=...
# ★배포 도메인이 정해지면 아래를 그 도메인으로 (예: https://genya-builder.onrender.com/auth/google/callback)
GOOGLE_OAUTH_REDIRECT=https://<배포도메인>/auth/google/callback

# ── 구글 서비스계정 (SA · 데모 폴백용) ──
# google-key.json 파일 "내용 전체"를 한 줄 JSON으로 붙여넣기
GOOGLE_SA_JSON={"type":"service_account","project_id":"...", ...}

# ── 캘린더 ──
CAL_ID=primary

# ── 카카오 로그인 (선택 · 안 쓰면 비워두세요) ──
KAKAO_REST_KEY=
KAKAO_REDIRECT=https://<배포도메인>/auth/kakao/callback

# ── 솔라피 / 카카오 알림톡 (오원트 org 채널 · Step 5) ──
# 솔라피 콘솔(solapi.com)에서 API Key 발급. 알림톡은 발신프로필(카카오 채널) 등록 + 템플릿 심사(3~5일) 후 사용.
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_PFID=            # 카카오 발신프로필 ID(채널 등록 후 발급)
SOLAPI_FROM=           # 발신번호(알림톡 실패 시 SMS 대체발송용, 숫자만)
# ★템플릿 심사 통과 후, 각 templateId를 아래에 주입(코드명 매핑). 미주입이면 그 템플릿은 '미승인'으로 정직 차단.
# ★다목적 8종(재무설계·필라테스·세무·행정·병의원 등 공용). 발신자는 문구 내 #{사업자명} 변수로 대응.
SOLAPI_TPL_CAR_INSURANCE_EXPIRY=   # 1. 자동차보험 만기 안내
SOLAPI_TPL_INSURANCE_EXPIRY=       # 2. 보험 만기 안내
SOLAPI_TPL_RENEWAL_NOTICE=         # 3. 갱신 안내(일반)
SOLAPI_TPL_BIRTHDAY=               # 4. 생일 축하
SOLAPI_TPL_ANNIVERSARY=            # 5. 결혼 기념일 축하
SOLAPI_TPL_MEETING_REMINDER=       # 6. 상담·미팅 리마인더
SOLAPI_TPL_PROGRAM_INFO=           # 7. 강의·세미나·수업 안내
SOLAPI_TPL_EVENT_INFO=             # 8. 일정·행사 안내

# ── 지니야 지능(Step 2-1 하이브리드 라우터) ──
COST_THRESHOLD_KRW=5000            # 일 비용 임계(원). 초기 5천 → 교육 5명 1만 → 10명+ 2~3만(회장님 결재)
# SIMULATE_CLAUDE_FAIL=1           # (스테이징 전용) 1이면 Claude 강제 실패 → gpt-4o 폴백 실측. 프로덕션 미설정.

# ── 포트 ──
# PORT는 Render가 자동으로 넣어줍니다 (직접 설정 불필요)
# RENDER 환경변수도 Render가 자동 주입 → HTTPS Secure 쿠키 자동 활성화
